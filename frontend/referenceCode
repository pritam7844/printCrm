  ::-webkit-scrollbar-thumb { background: var(--paper-3); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--ink-4); }

  /* ── MISC ── */
  .flex { display: flex; }
  .items-center { align-items: center; }
  .gap-8 { gap: 8px; }
  .gap-12 { gap: 12px; }
  .ml-auto { margin-left: auto; }
